# Desarrollo: rutas relativas + proxy de Nuxt (sin CORS ni certificado en el navegador)
NUXT_PUBLIC_API_BASE_URL=/api
NUXT_API_PROXY_TARGET=http://127.0.0.1:3000
# Si la API corre con DEV_HTTPS=true y certs locales:
# NUXT_API_PROXY_TARGET=https://127.0.0.1:3000

NUXT_PUBLIC_APP_NAME=Factosys Store

# En factosys-store-api (.env.development):
# FRONTEND_URL=http://localhost:3001
