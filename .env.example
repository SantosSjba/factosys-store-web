# =============================================================================
# FACTOSYS STORE WEB — Nuxt 4 (tienda + intranet admin)
# =============================================================================

# API (proxy en dev; URL absoluta en producción)
NUXT_PUBLIC_API_BASE_URL=/api
# Con DEV_HTTPS=true en la API (por defecto en dev local):
NUXT_API_PROXY_TARGET=https://127.0.0.1:3000
# Sin HTTPS en la API:
# NUXT_API_PROXY_TARGET=http://127.0.0.1:3000

NUXT_PUBLIC_APP_NAME=Factosys Store

# Producción (Coolify / VPS, Build Pack: Dockerfile):
# NUXT_PUBLIC_API_BASE_URL=https://api.tudominio.com/api
# NUXT_API_PROXY_TARGET=https://api.tudominio.com
# HOST=0.0.0.0
# PORT=3000
# NITRO_HOST=0.0.0.0
# NITRO_PORT=3000
# Health check en Coolify UI: GET /health (puerto 3000, start period ~90s)
