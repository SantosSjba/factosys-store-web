# =============================================================================
# FACTOSYS STORE WEB
# Local:  cp .env.example .env  (usa bloque LOCAL abajo)
# Coolify: pega el bloque PRODUCCIÓN en Environment Variables (bulk)
# =============================================================================

# --- PRODUCCIÓN (Coolify → factosys-store-web) ---
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

NUXT_PUBLIC_API_BASE_URL=/api
NUXT_API_PROXY_TARGET=https://api-store.factosysperu.com
NUXT_PUBLIC_APP_NAME=Factosys Store

# --- LOCAL (desarrollo en Mac) ---
# NODE_ENV=development
# HOST=0.0.0.0
# PORT=3001
# NITRO_HOST=0.0.0.0
# NITRO_PORT=3001
# NUXT_PUBLIC_API_BASE_URL=/api
# NUXT_API_PROXY_TARGET=https://127.0.0.1:3000
# NUXT_PUBLIC_APP_NAME=Factosys Store
